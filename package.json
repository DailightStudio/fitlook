{
  "name": "fitlook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:auto": "node scripts/migrate-db.js",
    "db:studio": "drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx src/lib/seed.ts",
    "db:seed-products": "dotenv -e .env.local -- tsx src/lib/seed-products.ts",
    "crawl": "dotenv -e .env.local -- tsx src/scripts/crawl-musinsa.ts",
    "spike:download": "dotenv -e .env.local -- tsx spike/download-tripo-samples.ts",
    "spike:fit": "tsx spike/run-weight-transfer.ts",
    "build:cf": "opennextjs-cloudflare build",
    "build:unity": "powershell -ExecutionPolicy Bypass -File scripts/build-unity.ps1",
    "setup:complete": "powershell -ExecutionPolicy Bypass -File setup-complete.ps1",
    "deploy": "npm run build:unity && opennextjs-cloudflare build && wrangler pages deploy",
    "preview:cf": "opennextjs-cloudflare build && wrangler pages dev"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@tailwindcss/postcss": "^4.3.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "jose": "^6.2.3",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "dotenv-cli": "^7.4.0",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.4.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.100.0"
  }
}
